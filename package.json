{
  "name": "@florentleveque/mural-mcp-serveur",
  "version": "1.2.0",
  "description": "Model Context Protocol server for Mural visual collaboration platform",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mural-mcp-serveur": "./build/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "prepare": "husky",
    "prepublishOnly": "pnpm build"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write",
    "src/**/*.ts": "eslint --fix"
  },
  "keywords": [
    "mcp",
    "mural",
    "visual-collaboration",
    "model-context-protocol",
    "ai",
    "llm",
    "oauth"
  ],
  "author": "Florent Lévêque <florent.leveque@digital4better.com>",
  "license": "MIT",
  "homepage": "https://github.com/florentleveque/mural-mcp-serveur#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/florentleveque/mural-mcp-serveur.git"
  },
  "bugs": {
    "url": "https://github.com/florentleveque/mural-mcp-serveur/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "dotenv": "^17.2.1",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "^22.19.20",
    "@vitest/coverage-v8": "^4.1.8",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "semantic-release": "^24.2.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
